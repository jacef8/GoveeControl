# Copy to .env (Railway: set these as service Variables). Never commit real keys.

# Govee Cloud API key — Govee Home app > Profile > Apply for API Key
GOVEE_API_KEY=

# Server-side Anthropic key for AI scenes/schedules
ANTHROPIC_API_KEY=

# Shared passcode the PWA must send (X-Passcode header). Leave blank to disable the gate.
PASSCODE=

# Token in the public IFTTT webhook URL (/hook/<token>/<event>). Defaults to PASSCODE if blank.
WEBHOOK_TOKEN=

# Optional: home lat/lon, required only for "sunset"/"sunrise" automations
LAT=
LON=

# Railway sets PORT automatically; only set locally if you want a fixed port
PORT=4319

# Persistence: point at a mounted Railway Volume (e.g. /data) so automations +
# triggers survive redeploys. Leave blank locally to use the server/ folder.
DATA_DIR=
